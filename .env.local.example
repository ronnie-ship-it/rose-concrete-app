# Copy to .env.local and fill in after creating your Supabase project

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # server-only, never expose
# Full Postgres connection string. Used by scripts/migrate.js to
# apply SQL migrations directly. Get it from Supabase Dashboard →
# Project Settings → Database → Connection string → URI (with the
# password filled in). Prefer the pooler URL on port 6543.
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron auth ---
# Shared secret for /api/cron/* GETs. Vercel's automatic cron sends
# `x-vercel-cron: 1` so this isn't strictly required for scheduled runs
# (lib/cron-auth accepts either signal), but it IS required for any
# external trigger — local `curl`, GitHub Actions, manual debug.
#
# Generate once with:
#   openssl rand -hex 32
#
# Then paste into BOTH .env.local and the Vercel project's env vars
# (Settings → Environment Variables → Production + Preview + Development).
CRON_SECRET=
ROSE_DEFAULT_WARRANTY_MONTHS=36
ROSE_DEFAULT_DEPOSIT_PERCENT=50
ROSE_DEFAULT_DEPOSIT_NONREFUNDABLE=true

# --- DocuSign (filled later, after beta access approved) ---
DOCUSIGN_ACCOUNT_ID=e9b3a88c-4fc1-4c86-a098-24e31ee82b13
DOCUSIGN_TEMPLATE_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_ACCESS_TOKEN=                # short-lived bearer token; refresh via JWT cron

# --- Marketing site / lead capture (sandiegoconcrete.ai) ---
# OpenPhone REST creds — used for outbound auto-SMS to new leads
# and for the existing /api/cron/openphone-backfill cron.
OPENPHONE_API_KEY=
# Pin which OpenPhone number sends the auto-text. Find it in
# OpenPhone → Settings → Phone Numbers (or via GET /v1/phone-numbers).
# If unset, the adapter falls back to the first number on the account.
OPENPHONE_PHONE_NUMBER_ID=

# Resend — outbound email. Get a key at https://resend.com/api-keys.
# Free tier covers 3k/mo, way more than we need.
RESEND_API_KEY=
# FROM address. For testing before sandiegoconcrete.ai is verified in
# Resend, leave as `Rose Concrete <onboarding@resend.dev>`. After verifying,
# switch to `Rose Concrete <leads@sandiegoconcrete.ai>`.
RESEND_FROM_EMAIL=Rose Concrete <onboarding@resend.dev>
# Optional Reply-To header (handy so customer replies bounce to ronnie@).
RESEND_REPLY_TO=ronnie@sandiegoconcrete.ai
# Where lead-notification emails are delivered.
LEAD_NOTIFICATION_EMAIL=ronnie@sandiegoconcrete.ai

# --- Analytics (Google Tag Manager / GA4 / Google Ads) ---
# All three load only on the (marketing) layout — never on /dashboard
# or /crew. Leave blank in dev so localhost traffic doesn't pollute
# real analytics.

# GTM container ID — looks like `GTM-XXXXXXX`. Optional. Use this if
# you want to manage tags via the GTM UI without touching code.
NEXT_PUBLIC_GTM_ID=

# GA4 measurement ID — looks like `G-XXXXXXXXXX`. Set this in Vercel
# production. The lead form fires `generate_lead` with value=1, currency
# USD, source_page = the landing-page slug. Showed up in 116k impressions
# / 618 clicks last quarter — preserve that with this set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads conversion tag — full send_to value, looks like
# `AW-1234567890/AbCdEfGhIjKlMnO`. Get from Ads → Tools → Conversions
# → "View tag setup" on the lead-form conversion action. Account ID
# 343-521-6133. Until set, the conversion fire is a no-op (the lead
# form still captures, the GA4 event still fires).
NEXT_PUBLIC_GADS_CONVERSION_ID=

# --- Call tracking (provider-agnostic webhook) ---
# Shared secret for the /api/calls/inbound endpoint. Leave blank until
# a tracking provider (CallRail, OpenPhone webhook, etc.) is selected.
CALL_TRACKING_WEBHOOK_SECRET=

# --- Anthropic API (project_media alt-text generation) ---
# When set, the project-photos uploader generates AI alt text for each
# photo via Claude Haiku Vision. When unset, uploads still succeed with
# a sensible fallback alt text. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# --- Gmail auto-attach (email → client + active project) ---
# OAuth 2 credentials for the watched mailbox (typically ronnie@).
# Generate at https://console.cloud.google.com — Gmail API enabled,
# OAuth consent screen in "Testing" mode is fine for one user. Scopes
# needed: https://www.googleapis.com/auth/gmail.readonly
#
# Then run the one-time script:
#   node scripts/gmail-oauth-bootstrap.js
# to exchange the auth code for a refresh token. Paste it here.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Web Push notifications (migration 035) ---
# Generate once with: npx web-push generate-vapid-keys
# The three VAPID_* vars are server-only; NEXT_PUBLIC_VAPID_PUBLIC_KEY is
# the same public key exposed to the browser so components/push-enroll
# can hand it to pushManager.subscribe().
# When unset, lib/push.sendPushToUser() logs-and-skips so nothing breaks.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ronnie@sandiegoconcrete.ai
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Optional modules (off by default) ---
GOOGLE_DRIVE_SYNC_ENABLED=false
GOOGLE_ADS_AUTONOMOUS_ENABLED=false
GOOGLE_ADS_SHADOW_MODE=true
